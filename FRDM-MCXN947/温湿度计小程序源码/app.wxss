page {
  --bg-start: #06121f;
  --bg-end: #0f2742;
  --panel: rgba(10, 23, 39, 0.72);
  --panel-border: rgba(148, 163, 184, 0.18);
  --text-main: #f8fafc;
  --text-sub: #cbd5e1;
  --mint: #69f0c1;
  --blue: #7dd3fc;
  --warm: #f9a826;
  --danger: #fb7185;
  background:
    radial-gradient(circle at top, rgba(125, 211, 252, 0.2), transparent 34%),
    linear-gradient(180deg, var(--bg-start), var(--bg-end));
  min-height: 100%;
  color: var(--text-main);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  line-height: normal;
  background: transparent;
}

button::after {
  border: none;
}
