.page {
  min-height: 100vh;
  padding: 34rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: #0b1220;
  color: #edf4ff;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.title {
  display: block;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
}

.radio {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.4);
  border-radius: 50%;
}

.radio-core {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #64748b;
}

.radio-active {
  border-color: rgba(45, 212, 191, 0.95);
  box-shadow: 0 0 30rpx rgba(45, 212, 191, 0.24);
}

.radio-active .radio-core {
  background: #2dd4bf;
}

.status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  background: rgba(15, 23, 42, 0.92);
}

.status-dot {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
}

.status-idle {
  color: #cbd5e1;
}

.status-busy {
  color: #bae6fd;
}

.status-success {
  color: #99f6e4;
}

.status-danger {
  color: #fecdd3;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.metric {
  min-height: 230rpx;
  padding: 26rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 16rpx;
  background: #111b2f;
  box-sizing: border-box;
}

.metric-temp {
  border-color: rgba(251, 146, 60, 0.32);
}

.metric-humidity {
  border-color: rgba(45, 212, 191, 0.32);
}

.metric-label {
  display: block;
  margin-bottom: 30rpx;
  font-size: 26rpx;
  color: #b6c5d8;
}

.metric-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.metric-value {
  max-width: 210rpx;
  font-size: 70rpx;
  line-height: 0.98;
  font-weight: 700;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-unit {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: #cbd5e1;
}

.panel {
  border: 2rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 16rpx;
  background: #111b2f;
  margin-bottom: 22rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 0 24rpx;
  border-bottom: 2rpx solid rgba(148, 163, 184, 0.12);
}

.detail-row:last-child {
  border-bottom: 0;
}

.detail-label {
  font-size: 25rpx;
  color: #94a3b8;
}

.detail-value {
  max-width: 440rpx;
  font-size: 25rpx;
  color: #e2e8f0;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hint {
  display: block;
  min-height: 96rpx;
  margin-bottom: 26rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #b6c5d8;
}

.primary-btn {
  height: 96rpx;
  border-radius: 16rpx;
  color: #06111f;
  font-size: 31rpx;
  font-weight: 700;
  background: #5eead4;
}

.primary-btn-stop {
  color: #ffffff;
  background: #ef4444;
}
